# Copie ce fichier en .env et remplis les valeurs pour la production.
# En développement, l'app fonctionne sans .env (valeurs par défaut dans config.py).

# Clé secrète Flask (sessions). Génère-en une avec: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Clé secrète pour signer les tokens JWT
JWT_SECRET_KEY=

# URL de la base de données. Vide = SQLite local (sqlite:///studyhub.db)
# Exemple PostgreSQL: postgresql://user:password@localhost:5432/studyhub
DATABASE_URL=
